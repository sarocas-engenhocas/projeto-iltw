{
  "version": 2,
  "builds": [
    { "src": "public/**/*", "use": "@vercel/static" },
    { "src": "Dados/**/*", "use": "@vercel/static" },
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/login", "dest": "server.js" },
    { "src": "/register", "dest": "server.js" },
    { "src": "/api/balde", "dest": "server.js" },
    { "src": "/Dados/(.*)", "dest": "/Dados/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
